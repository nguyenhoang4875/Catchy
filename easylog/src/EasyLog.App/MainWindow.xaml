<Window x:Class="EasyLog.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:infra="clr-namespace:EasyLog.App.Infrastructure"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Icon="Assets/easylog.ico"
        Width="1380"
        Height="820"
        MinWidth="1080"
        MinHeight="700"
        Background="#F9FAFB"
        FontFamily="{Binding SelectedAppFontFamily}"
        AllowDrop="True"
        DragOver="OnWindowDragOver"
        Drop="OnWindowDrop">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="InputForegroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="InputSelectionBrush" Color="#60A5FA" />
        <SolidColorBrush x:Key="GridBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="GridAltBackgroundBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="GridForegroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="GridBorderBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="GridSelectionBrush" Color="#BFDBFE" />
        <SolidColorBrush x:Key="GridSelectionBorderBrush" Color="#60A5FA" />
        <SolidColorBrush x:Key="GridHeaderBackgroundBrush" Color="#F3F4F6" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />

        <Style x:Key="LogGridTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{Binding ForegroundBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridCell}}" Value="True">
                    <Setter Property="Foreground" Value="#111827" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InputForegroundBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource InputForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
            <Setter Property="SelectionBrush" Value="{StaticResource InputSelectionBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InputForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#111827" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="MenuItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="CheckedGlyph"
                                           Text="✓"
                                           Foreground="#7C3AED"
                                           FontWeight="SemiBold"
                                           Margin="0,0,7,0"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed" />
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center" />
                                <TextBlock x:Name="SubmenuArrow"
                                           Grid.Column="2"
                                           Text="›"
                                           Foreground="#64748B"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Margin="14,0,0,0"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed" />
                                <Popup x:Name="PART_Popup"
                                       Grid.ColumnSpan="3"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Right"
                                       PopupAnimation="Fade">
                                    <Border Background="#FFFFFF"
                                            BorderBrush="#CBD5E1"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="6"
                                            MinWidth="220">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.16" />
                                        </Border.Effect>
                                        <ScrollViewer CanContentScroll="True">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="Transparent" />
                                <Setter TargetName="MenuItemBorder" Property="BorderBrush" Value="Transparent" />
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckedGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="#F5F3FF" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="#EDE9FE" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Background="#E5E7EB"
                                Margin="4,6" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F5F3FF" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#A78BFA" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EDE9FE" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#7C3AED" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#DCFCE7" />
            <Setter Property="Foreground" Value="#166534" />
            <Setter Property="BorderBrush" Value="#22C55E" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#BBF7D0" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#16A34A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#86EFAC" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#15803D" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FEE2E2" />
            <Setter Property="Foreground" Value="#991B1B" />
            <Setter Property="BorderBrush" Value="#F87171" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FECACA" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#EF4444" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FCA5A5" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#DC2626" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource GridBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource GridForegroundBrush}" />
            <Setter Property="RowBackground" Value="{StaticResource GridBackgroundBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource GridAltBackgroundBrush}" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridBorderBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource GridBorderBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource GridBorderBrush}" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{Binding BackgroundBrush}" />
            <Setter Property="Foreground" Value="{Binding ForegroundBrush}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource GridSelectionBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource GridForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{Binding ForegroundBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource GridSelectionBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource GridForegroundBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource GridSelectionBorderBrush}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource GridSelectionBorderBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource GridForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource GridHeaderBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource GridForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource GridBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="SeparatorBrush" Value="#94A3B8" />
            <Setter Property="SeparatorVisibility" Value="Visible" />
        </Style>

        <DropShadowEffect x:Key="DialogShadow"
                          Color="Black"
                          BlurRadius="24"
                          ShadowDepth="4"
                          Opacity="0.6"
                          Direction="270" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBackgroundBrush}"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,8">
            <DockPanel>
                <Border DockPanel.Dock="Right"
                        Background="#F8FAFC"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="6"
                        VerticalAlignment="Center">
                    <Menu Background="Transparent"
                          BorderThickness="0"
                          VerticalAlignment="Center">
                    <MenuItem Header="More ▾" Padding="12,5">
                        <MenuItem Header="🧹 Clear Logs..." Command="{Binding ClearLogsCommand}" />
                        <Separator />
                        <MenuItem Header="⚙ Settings">
                            <MenuItem Header="Appearance">
                                <MenuItem StaysOpenOnClick="True" Padding="10,8">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Font Family" Width="92" VerticalAlignment="Center" />
                                            <ComboBox Width="170" Height="28"
                                                      ItemsSource="{Binding AppFontFamilies}"
                                                      SelectedItem="{Binding SelectedAppFontFamily}" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem StaysOpenOnClick="True" Padding="10,8">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Log Font Size" Width="92" VerticalAlignment="Center" />
                                            <Button Content="A-"
                                                    Command="{Binding DecreaseFontSizeCommand}"
                                                    Padding="9,3"
                                                    Margin="0,0,6,0" />
                                            <TextBlock Text="{Binding LogFontSizeLabel}"
                                                       Width="34"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#111827" />
                                            <Button Content="A+"
                                                    Command="{Binding IncreaseFontSizeCommand}"
                                                    Padding="9,3"
                                                    Margin="6,0,0,0" />
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                            </MenuItem>
                            <MenuItem Header="Live Defaults">
                                <MenuItem Header="새 로그만 / Live only" Command="{Binding SetLiveLookbackCommand}" CommandParameter="live" IsCheckable="True" IsChecked="{Binding IsLiveLookbackLiveOnlySelected, Mode=OneWay}" />
                                <MenuItem Header="최근 10초 포함 / Last 10 sec" Command="{Binding SetLiveLookbackCommand}" CommandParameter="10s" IsCheckable="True" IsChecked="{Binding IsLiveLookbackLast10SecondsSelected, Mode=OneWay}" />
                                <MenuItem Header="최근 30초 포함 / Last 30 sec" Command="{Binding SetLiveLookbackCommand}" CommandParameter="30s" IsCheckable="True" IsChecked="{Binding IsLiveLookbackLast30SecondsSelected, Mode=OneWay}" />
                                <MenuItem Header="최근 2분 포함 / Last 2 min" Command="{Binding SetLiveLookbackCommand}" CommandParameter="2m" IsCheckable="True" IsChecked="{Binding IsLiveLookbackLast2MinutesSelected, Mode=OneWay}" />
                            </MenuItem>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="ℹ About LogPilot" Click="OnAboutClick" />
                    </MenuItem>
                    </Menu>
                </Border>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="📂 Open Log"
                            Command="{Binding OpenFileCommand}"
                            Margin="0,0,8,0"
                            Padding="12,6" />
                    <Button Content="💾 Export Logs"
                            Command="{Binding ExportLogsCommand}"
                            Margin="0,0,12,0"
                            Padding="12,6" />
                    <Ellipse Width="12"
                             Height="12"
                             Fill="{Binding AdbConnectionIndicatorBrush}"
                             Stroke="#6B7280"
                             StrokeThickness="1"
                             VerticalAlignment="Center"
                             ToolTip="{Binding AdbConnectionStatusText}"
                             Margin="0,0,12,0" />

                    <TextBlock Text="Device"
                               Foreground="#374151"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <ComboBox Width="240"
                              Height="30"
                              Margin="0,0,4,0"
                              ItemsSource="{Binding Devices}"
                              SelectedItem="{Binding SelectedDevice}"
                              Background="White"
                              Foreground="#111827"
                              BorderBrush="#D1D5DB">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="#111827" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="⟳"
                            Command="{Binding DiscoverDevicesCommand}"
                            ToolTip="Refresh device list"
                            Margin="0,0,8,0"
                            Padding="10,6" />

                    <Button Content="▶ Start Live"
                            Command="{Binding StartLiveCommand}"
                            ToolTip="Start live with the selected default backfill"
                            Margin="0,0,0,0"
                            Padding="12,6" />
                    <Menu Background="Transparent"
                          BorderThickness="0"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0">
                        <MenuItem Header="▼" Padding="8,4">
                            <MenuItem Header="새 로그만 / Live only" Command="{Binding StartLiveWithLookbackCommand}" CommandParameter="live" IsCheckable="True" IsChecked="{Binding IsLiveLookbackLiveOnlySelected, Mode=OneWay}" />
                            <MenuItem Header="최근 10초 포함 / Last 10 sec" Command="{Binding StartLiveWithLookbackCommand}" CommandParameter="10s" IsCheckable="True" IsChecked="{Binding IsLiveLookbackLast10SecondsSelected, Mode=OneWay}" />
                            <MenuItem Header="최근 30초 포함 / Last 30 sec" Command="{Binding StartLiveWithLookbackCommand}" CommandParameter="30s" IsCheckable="True" IsChecked="{Binding IsLiveLookbackLast30SecondsSelected, Mode=OneWay}" />
                            <MenuItem Header="최근 2분 포함 / Last 2 min" Command="{Binding StartLiveWithLookbackCommand}" CommandParameter="2m" IsCheckable="True" IsChecked="{Binding IsLiveLookbackLast2MinutesSelected, Mode=OneWay}" />
                        </MenuItem>
                    </Menu>
                    <Button Content="■ Stop Live"
                            Command="{Binding StopLiveCommand}"
                            Margin="0,0,8,0"
                            Padding="12,6" />

                    <CheckBox Content="Pause"
                              IsChecked="{Binding IsLiveAppendPaused}"
                              IsEnabled="{Binding IsLiveSessionRunning}"
                              Foreground="#111827"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0" />
                    <CheckBox Content="Auto"
                              IsChecked="{Binding IsAutoScrollEnabled}"
                              ToolTip="Auto Scroll"
                              Foreground="#111827"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0" />
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#6B7280"
                               Margin="0,0,12,0">
                        <Run Text="Pending " />
                        <Run Text="{Binding PausedAppendCount, Mode=OneWay, StringFormat={}{0:n0}}" />
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource PanelBackgroundBrush}"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,8">
            <DockPanel>
                <TextBlock Text="Search"
                           Foreground="#374151"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           DockPanel.Dock="Left" />
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal">
                    <Grid Margin="0,0,8,0">
                        <TextBox x:Name="SearchInputBox"
                                 MinWidth="720"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewKeyDown="OnSearchInputPreviewKeyDown"
                                 GotFocus="OnSearchInputGotFocus"
                                 LostFocus="OnSearchInputLostFocus"
                                 VerticalContentAlignment="Center"
                                 Padding="8,4" />
                        <Popup x:Name="SearchHistoryPopup"
                               PlacementTarget="{Binding ElementName=SearchInputBox}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               PopupAnimation="Slide"
                               MaxHeight="320">
                            <Border Background="#FFFFFF"
                                    BorderBrush="#CBD5E1"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Margin="0,2,0,0"
                                    MinWidth="{Binding ActualWidth, ElementName=SearchInputBox}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" />
                                </Border.Effect>
                                <ListBox x:Name="SearchHistoryListBox"
                                         ItemsSource="{Binding SearchHistory}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         PreviewMouseLeftButtonUp="OnSearchHistoryItemClick"
                                         PreviewKeyDown="OnSearchHistoryListBoxPreviewKeyDown">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="2,1">
                                                <Button DockPanel.Dock="Right"
                                                        Content="✕"
                                                        FontSize="10"
                                                        Foreground="#9CA3AF"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Padding="6,2"
                                                        Margin="4,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding DataContext.RemoveSearchHistoryItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Remove from history" />
                                                <TextBlock Text="{Binding}"
                                                           Foreground="#111827"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           Padding="4,3" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="4,2" />
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F3F4F6" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#DBEAFE" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </Border>
                        </Popup>
                    </Grid>
                    <Button Content="Find"
                            Command="{Binding SearchLogsCommand}"
                            Margin="0,0,8,0"
                            Padding="12,6" />
                    <Button Content="Clear Search"
                            Command="{Binding ClearSearchCommand}"
                            Margin="0,0,12,0"
                            Padding="12,6" />
                    <CheckBox Content="Search All Logs (ignore filter)"
                              IsChecked="{Binding IsSearchInAllLogs}"
                              Foreground="#111827"
                              VerticalAlignment="Center"
                              Margin="4,0,0,0"
                              ToolTip="Checked: search across all loaded logs.&#x0a;Unchecked: search only within currently filtered logs." />
                    </StackPanel>
                    <TextBlock Foreground="#64748B"
                               FontSize="10.5"
                               Margin="0,4,0,0">
                        <Run Text="Operators: " />
                        <Run Text="|" Foreground="#7C3AED" FontWeight="SemiBold" />
                        <Run Text=" OR   " />
                        <Run Text="&amp;" Foreground="#7C3AED" FontWeight="SemiBold" />
                        <Run Text=" AND" />
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="460" MinWidth="340" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBackgroundBrush}"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#F8FAFC"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Filter Set"
                                       Foreground="#111827"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="{Binding CurrentFilterSetDisplayName}"
                                       Foreground="#6B7280"
                                       Margin="0,0,0,8" />
                            <WrapPanel>
                                <Button Content="New Set" Command="{Binding NewFilterSetCommand}" Margin="0,0,8,8" Padding="10,4" />
                                <Button Content="Load Set" Command="{Binding OpenFilterSetCommand}" Margin="0,0,8,8" Padding="10,4" />
                                <Button Content="Save Set" Command="{Binding SaveFilterSetCommand}" Margin="0,0,8,8" Padding="10,4" />
                                <Button Content="Save Set As" Command="{Binding SaveFilterSetAsCommand}" Margin="0,0,8,8" Padding="10,4" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Filter Rules"
                                           Foreground="#111827"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="Enabled rules filter the current view and highlight matching logs."
                                           Foreground="#6B7280"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />
                                <WrapPanel Margin="0,0,0,8">
                                    <Button Content="Add..." Command="{Binding AddFilterRuleCommand}" Margin="0,0,8,8" Padding="10,4" />
                                    <Button Content="Edit..." Command="{Binding EditSelectedFilterRuleCommand}" Margin="0,0,8,8" Padding="10,4" />
                                    <Button Content="Enable Selected" Command="{Binding EnableSelectedFilterRuleCommand}" Style="{StaticResource SuccessButtonStyle}" Margin="0,0,8,8" Padding="10,4" />
                                    <Button Content="Disable Selected" Command="{Binding DisableSelectedFilterRuleCommand}" Style="{StaticResource DangerButtonStyle}" Margin="0,0,8,8" Padding="10,4" />
                                     <Button Content="Delete Current" Command="{Binding DeleteSelectedFilterPresetCommand}" Margin="0,0,8,8" Padding="10,4" />
                                </WrapPanel>
                            </StackPanel>

                            <ListBox x:Name="FilterRulesListBox"
                                     ItemsSource="{Binding FilterPresets}"
                                     SelectedItem="{Binding SelectedFilterPreset}"
                                     MouseDoubleClick="OnFilterRulesListBoxMouseDoubleClick"
                                      PreviewMouseLeftButtonDown="OnFilterRulesListBoxPreviewMouseLeftButtonDown"
                                      PreviewMouseRightButtonDown="OnFilterRulesListBoxPreviewMouseRightButtonDown"
                                      MouseMove="OnFilterRulesListBoxMouseMove"
                                      AllowDrop="True"
                                      DragOver="OnFilterRulesListBoxDragOver"
                                      Drop="OnFilterRulesListBoxDrop"
                                     Background="#FFFFFF"
                                     Foreground="#111827"
                                     BorderBrush="#CBD5E1"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Add..." Click="OnListBoxContextMenuAddClick" />
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.Template>
                                    <ControlTemplate TargetType="ListBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <DockPanel>
                                                <Grid DockPanel.Dock="Top" Margin="8,8,8,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Content="Select all"
                                                              FontSize="11"
                                                              IsChecked="{Binding AreAllFilterRulesSelected, Mode=TwoWay}"
                                                              Foreground="#111827"
                                                              VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding CheckedFilterRulesSummary}"
                                                               FontSize="11"
                                                               Foreground="#6B7280"
                                                               VerticalAlignment="Center"
                                                               Margin="8,0,0,0" />
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <Button Content="↑"
                                                                Command="{Binding MoveSelectedFilterRuleUpCommand}"
                                                                Width="24"
                                                                Height="22"
                                                                Margin="0,0,4,0"
                                                                FontSize="11"
                                                                Padding="0" />
                                                        <Button Content="↓"
                                                                Command="{Binding MoveSelectedFilterRuleDownCommand}"
                                                                Width="24"
                                                                Height="22"
                                                                FontSize="11"
                                                                Padding="0" />
                                                    </StackPanel>
                                                </Grid>
                                                <ScrollViewer Focusable="False"
                                                              HorizontalScrollBarVisibility="Disabled"
                                                              VerticalScrollBarVisibility="Auto">
                                                    <ItemsPresenter />
                                                </ScrollViewer>
                                            </DockPanel>
                                        </Border>
                                    </ControlTemplate>
                                </ListBox.Template>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                         <Border Margin="4,4"
                                                 Padding="4"
                                                 Background="Transparent"
                                                 CornerRadius="6"
                                                 PreviewMouseLeftButtonDown="OnFilterRuleItemPreviewMouseLeftButtonDown">
                                             <Border.ContextMenu>
                                                 <ContextMenu>
                                                     <MenuItem Header="Add..."
                                                               Click="OnListBoxContextMenuAddClick" />
                                                     <MenuItem Header="Edit..."
                                                               Click="OnEditFilterRuleMenuItemClick" />
                                                     <MenuItem Header="Delete"
                                                               Click="OnDeleteFilterRuleMenuItemClick" />
                                                 </ContextMenu>
                                             </Border.ContextMenu>
                                             <DockPanel>
                                                 <CheckBox IsChecked="{Binding IsBatchSelected}"
                                                           VerticalAlignment="Top"
                                                           Margin="0,1,8,0" />
                                                 <Border Width="18"
                                                         Height="18"
                                                         CornerRadius="4"
                                                         Background="{Binding ColorBrush}"
                                                         BorderBrush="#E5E7EB"
                                                         BorderThickness="1"
                                                         Margin="0,2,8,0" />
                                                 <StackPanel>
                                                     <DockPanel Margin="0,0,0,2">
                                                         <Border DockPanel.Dock="Right"
                                                                CornerRadius="4"
                                                                Padding="6,2"
                                                                MinWidth="36"
                                                                VerticalAlignment="Center"
                                                                Margin="8,0,0,0">
                                                             <Border.Style>
                                                                 <Style TargetType="Border">
                                                                     <Setter Property="Background" Value="Transparent" />
                                                                     <Style.Triggers>
                                                                         <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                             <Setter Property="Background" Value="#16A34A" />
                                                                         </DataTrigger>
                                                                     </Style.Triggers>
                                                                 </Style>
                                                             </Border.Style>
                                                             <TextBlock FontSize="11"
                                                                        FontWeight="Bold"
                                                                        HorizontalAlignment="Center">
                                                                 <TextBlock.Style>
                                                                     <Style TargetType="TextBlock">
                                                                         <Setter Property="Text" Value="OFF" />
                                                                         <Setter Property="Foreground" Value="#9CA3AF" />
                                                                         <Style.Triggers>
                                                                             <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                                 <Setter Property="Text" Value="ON" />
                                                                                 <Setter Property="Foreground" Value="White" />
                                                                             </DataTrigger>
                                                                         </Style.Triggers>
                                                                     </Style>
                                                                 </TextBlock.Style>
                                                             </TextBlock>
                                                         </Border>
                                                         <TextBlock Text="{Binding Name}"
                                                                    Foreground="#111827"
                                                                    FontWeight="SemiBold"
                                                                    TextTrimming="CharacterEllipsis" />
                                                     </DockPanel>
                                                     <TextBlock Text="{Binding Summary}"
                                                                Foreground="#6B7280"
                                                                TextWrapping="Wrap" />
                                                 </StackPanel>
                                             </DockPanel>
                                         </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Background="#F8FAFC"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8"
                            Margin="0,8,0,0"
                            MaxHeight="220"
                            MinHeight="60">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                                <TextBlock Text="Preview"
                                           Foreground="#111827"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,2" />
                                <TextBox Text="{Binding PreviewHeader, Mode=OneWay}"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="#374151"
                                         FontSize="11"
                                         FontFamily="Consolas"
                                         Padding="0"
                                         Margin="0,0,0,2"
                                         TextWrapping="NoWrap" />
                            </StackPanel>
                            <TextBox x:Name="PreviewTextBox"
                                     Text="{Binding PreviewMessage, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Background="#FFFFFF"
                                     Foreground="#111827"
                                     BorderBrush="#CBD5E1"
                                     FontSize="{Binding LogFontSize}"
                                     FontFamily="Consolas"
                                     Padding="4" />
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          Background="#CBD5E1"
                          ShowsPreview="True" />

            <Border Grid.Column="2"
                    Background="{StaticResource PanelBackgroundBrush}"
                    CornerRadius="8"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="180" MinHeight="120" />
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="LogGrid"
                              Grid.Row="0"
                              ItemsSource="{Binding Records}"
                              SelectedItem="{Binding SelectedRow}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              ClipboardCopyMode="None"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                                  Background="#FFFFFF"
                                  Foreground="#111827"
                              BorderThickness="0"
                              FontSize="{Binding LogFontSize}"
                              PreviewMouseWheel="OnLogGridPreviewMouseWheel"
                               PreviewMouseLeftButtonDown="OnLogGridPreviewMouseLeftButtonDown"
                               ScrollViewer.ScrollChanged="OnLogGridScrollChanged">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy Rows (Ctrl+C)" Click="OnCopyRowsClick" />
                                <MenuItem Header="Copy Message Only" Click="OnCopyMessageClick" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding RowId}" Width="70" ElementStyle="{StaticResource LogGridTextStyle}" />
                            <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="150" ElementStyle="{StaticResource LogGridTextStyle}" />
                            <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="80" ElementStyle="{StaticResource LogGridTextStyle}" />
                            <DataGridTemplateColumn Header="Tag" Width="190" ClipboardContentBinding="{Binding Tag}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource LogGridTextStyle}"
                                                   infra:HighlightedTextBehavior.Text="{Binding Tag}"
                                                   infra:HighlightedTextBehavior.Terms="{Binding DataContext.SearchHighlightTerms, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   infra:HighlightedTextBehavior.HighlightBackground="#FDE68A"
                                                   infra:HighlightedTextBehavior.HighlightForeground="#111827" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="PID" Width="90" ClipboardContentBinding="{Binding Pid}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource LogGridTextStyle}"
                                                   infra:HighlightedTextBehavior.Text="{Binding Pid}"
                                                   infra:HighlightedTextBehavior.Terms="{Binding DataContext.SearchHighlightTerms, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   infra:HighlightedTextBehavior.HighlightBackground="#FDE68A"
                                                   infra:HighlightedTextBehavior.HighlightForeground="#111827" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="TID" Binding="{Binding Tid}" Width="90" ElementStyle="{StaticResource LogGridTextStyle}" />
                            <DataGridTemplateColumn Header="Message" Width="900" MinWidth="420" ClipboardContentBinding="{Binding Message}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource LogGridTextStyle}"
                                                   TextWrapping="NoWrap"
                                                   infra:HighlightedTextBehavior.Text="{Binding Message}"
                                                   infra:HighlightedTextBehavior.Terms="{Binding DataContext.SearchHighlightTerms, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   infra:HighlightedTextBehavior.HighlightBackground="#FDE68A"
                                                   infra:HighlightedTextBehavior.HighlightForeground="#111827" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Row="1"
                                  Height="6"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeBehavior="PreviousAndNext"
                                  Background="#374151"
                                  ShowsPreview="True"
                                  Visibility="{Binding IsSearchPaneVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <Border Grid.Row="2"
                            Background="#FFFFFF"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8">
                        <DockPanel>
                            <TextBlock Text="Search Results"
                                       Foreground="#111827"
                                       FontWeight="SemiBold"
                                       DockPanel.Dock="Top"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="{Binding SearchStatusText}"
                                       Foreground="#6B7280"
                                       DockPanel.Dock="Top"
                                       Margin="0,0,0,8" />
                            <DataGrid x:Name="SearchResultsGrid"
                                      ItemsSource="{Binding SearchResults}"
                                      SelectedItem="{Binding SelectedSearchResult}"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      SelectionMode="Extended"
                                      SelectionUnit="FullRow"
                                      ClipboardCopyMode="None"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.CanContentScroll="True"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0"
                                      Background="#FFFFFF"
                                      Foreground="#111827"
                                      BorderThickness="0"
                                      FontSize="{Binding LogFontSize}"
                                      PreviewMouseLeftButtonDown="OnLogGridPreviewMouseLeftButtonDown">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Copy Rows (Ctrl+C)" Click="OnCopyRowsClick" />
                                        <MenuItem Header="Copy Message Only" Click="OnCopyMessageClick" />
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding RowId}" Width="70" ElementStyle="{StaticResource LogGridTextStyle}" />
                                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="150" ElementStyle="{StaticResource LogGridTextStyle}" />
                                    <DataGridTemplateColumn Header="Tag" Width="180" ClipboardContentBinding="{Binding Tag}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource LogGridTextStyle}"
                                                           infra:HighlightedTextBehavior.Text="{Binding Tag}"
                                                           infra:HighlightedTextBehavior.Terms="{Binding DataContext.SearchHighlightTerms, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           infra:HighlightedTextBehavior.HighlightBackground="#FDE68A"
                                                           infra:HighlightedTextBehavior.HighlightForeground="#111827" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="PID" Width="90" ClipboardContentBinding="{Binding Pid}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource LogGridTextStyle}"
                                                           infra:HighlightedTextBehavior.Text="{Binding Pid}"
                                                           infra:HighlightedTextBehavior.Terms="{Binding DataContext.SearchHighlightTerms, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           infra:HighlightedTextBehavior.HighlightBackground="#FDE68A"
                                                           infra:HighlightedTextBehavior.HighlightForeground="#111827" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Message" Width="900" MinWidth="420" ClipboardContentBinding="{Binding Message}">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource LogGridTextStyle}"
                                                           TextWrapping="NoWrap"
                                                           infra:HighlightedTextBehavior.Text="{Binding Message}"
                                                           infra:HighlightedTextBehavior.Terms="{Binding DataContext.SearchHighlightTerms, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           infra:HighlightedTextBehavior.HighlightBackground="#FDE68A"
                                                           infra:HighlightedTextBehavior.HighlightForeground="#111827" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Background="{StaticResource PanelBackgroundBrush}"
                CornerRadius="8"
                Padding="10"
                Margin="0,8,0,0">
            <DockPanel>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="#111827"
                           DockPanel.Dock="Left" />
            </DockPanel>
        </Border>

        <Border Grid.RowSpan="4"
                Panel.ZIndex="1000"
                Background="#CC111827"
                CornerRadius="8"
                Padding="16,10"
                Width="360"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,16,16,0"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="Loading..."
                           Foreground="White"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding BusyMessage}"
                           Foreground="#E5E7EB"
                           Margin="0,4,0,0"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap" />
                <Button Content="✕ Cancel"
                        Click="OnCancelFileLoadClick"
                        Visibility="{Binding IsFileLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                        Margin="0,8,0,0"
                        Padding="12,4"
                        HorizontalAlignment="Left"
                        Background="#EF4444"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand" />
            </StackPanel>
        </Border>

        <!-- In-app Load Option Overlay -->
        <Grid Grid.RowSpan="4"
              Panel.ZIndex="2000"
              Visibility="{Binding IsLoadOptionVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <!-- Semi-transparent backdrop -->
            <Border Background="#660F172A"
                    MouseDown="OnLoadOptionBackdropMouseDown" />
            <!-- Dialog card -->
            <Border Background="#FFFFFF"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="28,24"
                    MinWidth="380"
                    MaxWidth="460"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{StaticResource DialogShadow}">
                <StackPanel>
                    <TextBlock Text="Log Load Option / 로그 로드 옵션"
                               Foreground="#111827"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBlock Text="Choose how much of the selected log should be rendered."
                               Foreground="#6B7280"
                               FontSize="12"
                               Margin="0,0,0,16" />

                    <Button Click="OnLoadOptionFullClick"
                            Cursor="Hand"
                            Margin="0,0,0,8"
                            Padding="14,10"
                            HorizontalContentAlignment="Left"
                            Background="#F5F3FF"
                            Foreground="#4C1D95"
                            BorderBrush="#C4B5FD"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="전체 로그 로드 / Load All Logs"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="모든 로그를 로드합니다. Load all log records."
                                       Foreground="#6D28D9"
                                       FontSize="11"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Button>

                    <Button Click="OnLoadOptionFilteredClick"
                            Cursor="Hand"
                            Margin="0,0,0,8"
                            Padding="14,10"
                            HorizontalContentAlignment="Left"
                            Background="#F8FAFC"
                            Foreground="#111827"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="필터 적용 로드 / Load Filtered Logs"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="현재 필터에 맞는 로그만 로드합니다. Load only matching logs."
                                       Foreground="#64748B"
                                       FontSize="11"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Button>

                    <Button Content="취소 / Cancel"
                            Click="OnLoadOptionCancelClick"
                            Cursor="Hand"
                            Padding="14,8"
                            HorizontalAlignment="Right"
                            Background="#FFFFFF"
                            Foreground="#374151"
                            BorderThickness="1"
                            BorderBrush="#CBD5E1"
                            Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

