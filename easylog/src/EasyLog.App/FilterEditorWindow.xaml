<Window x:Class="EasyLog.App.FilterEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:EasyLog.App.Models"
        mc:Ignorable="d"
        Title="{Binding DialogTitle, RelativeSource={RelativeSource Self}}"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        PreviewKeyDown="OnWindowPreviewKeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="InputForegroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#CBD5E1" />

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InputForegroundBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource InputForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InputForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
        </Style>
    </Window.Resources>

    <Grid x:Name="OverlayRoot"
          Background="Transparent"
          MouseDown="OnOverlayMouseDown">
        <Border x:Name="DialogCard"
                Width="620"
                Height="700"
                MinWidth="560"
                MinHeight="620"
                Background="#F9FAFB"
                BorderBrush="#4B5563"
                BorderThickness="1.5"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.35" Color="#000000" />
            </Border.Effect>
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                <TextBlock Text="Configure Log Filter"
                           Foreground="#111827"
                           FontWeight="SemiBold"
                           FontSize="16"
                           Margin="0,0,0,12" />

                <Grid Margin="0,0,0,12"
                      Visibility="{Binding ShowNameField, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Rule Name"
                               Foreground="#111827"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <TextBox Grid.Column="1"
                             Text="{Binding WorkingPreset.Name, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <Grid Margin="0,0,0,12"
                      Visibility="{Binding ShowColorField, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Highlight Color"
                               Foreground="#111827"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding ColorOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding SelectedColor, RelativeSource={RelativeSource AncestorType=Window}}"
                              Height="34">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:FilterColorOption}">
                                <DockPanel>
                                    <Border Width="72"
                                            Height="20"
                                            Background="{Binding BackgroundBrush}"
                                            BorderBrush="{Binding BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding DisplayLabel}"
                                               Foreground="{Binding BackgroundBrush}"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <Border Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Include Matches"
                                   Foreground="#111827"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="Text / Message (| separated)"
                                   Foreground="#6B7280" />
                        <TextBox Text="{Binding WorkingPreset.TextFilterText, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,10" />
                        <TextBlock Text="Tag (| separated)"
                                   Foreground="#6B7280" />
                        <TextBox Text="{Binding WorkingPreset.TagFilterText, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,10" />
                        <TextBlock Text="PID (| separated)"
                                   Foreground="#6B7280" />
                        <TextBox Text="{Binding WorkingPreset.PidFilterText, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Exclude Matches"
                                   Foreground="#111827"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="Exclude Text / Message (| separated)"
                                   Foreground="#6B7280" />
                        <TextBox Text="{Binding WorkingPreset.ExcludedTextFilterText, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,10" />
                        <TextBlock Text="Exclude Tag (| separated)"
                                   Foreground="#6B7280" />
                        <TextBox Text="{Binding WorkingPreset.ExcludedTagFilterText, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,10" />
                        <TextBlock Text="Exclude PID (| separated)"
                                   Foreground="#6B7280" />
                        <TextBox Text="{Binding WorkingPreset.ExcludedPidFilterText, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Log Levels"
                                   Foreground="#111827"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <WrapPanel>
                            <CheckBox Content="Verbose" IsChecked="{Binding WorkingPreset.IsVerboseEnabled, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#111827" Margin="0,0,12,8" />
                            <CheckBox Content="Debug" IsChecked="{Binding WorkingPreset.IsDebugEnabled, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#111827" Margin="0,0,12,8" />
                            <CheckBox Content="Info" IsChecked="{Binding WorkingPreset.IsInfoEnabled, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#111827" Margin="0,0,12,8" />
                            <CheckBox Content="Warn" IsChecked="{Binding WorkingPreset.IsWarnEnabled, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#111827" Margin="0,0,12,8" />
                            <CheckBox Content="Error" IsChecked="{Binding WorkingPreset.IsErrorEnabled, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#111827" Margin="0,0,12,8" />
                            <CheckBox Content="Fatal" IsChecked="{Binding WorkingPreset.IsFatalEnabled, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#111827" Margin="0,0,12,8" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,12,0,0">
                    <Button Content="Cancel"
                            Width="96"
                            IsCancel="True"
                            Margin="0,0,8,0"
                            Click="OnCancelClicked" />
                    <Button Content="OK"
                            Width="96"
                            IsDefault="True"
                            Click="OnOkClicked" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

