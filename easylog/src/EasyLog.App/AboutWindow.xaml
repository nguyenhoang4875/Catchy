<Window x:Class="EasyLog.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About LogPilot"
        Width="420"
        Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Icon="Assets/easylog.ico"
        Background="#F9FAFB">
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="4" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- App Name (selectable) -->
        <TextBox Grid.Row="0"
                 Text="LogPilot - AAOS Log Viewer"
                 FontSize="20"
                 FontWeight="Bold"
                 Foreground="#111827"
                 Background="Transparent"
                 BorderThickness="0"
                 IsReadOnly="True"
                 IsTabStop="False"
                 Cursor="Arrow" />

        <!-- Version (selectable) -->
        <TextBox Grid.Row="2"
                 x:Name="VersionText"
                 FontSize="13"
                 Foreground="#6B7280"
                 Background="Transparent"
                 BorderThickness="0"
                 IsReadOnly="True"
                 IsTabStop="False"
                 Cursor="Arrow" />

        <!-- Copyright (selectable) -->
        <TextBox Grid.Row="4"
                 Text="© 2025-2026 LG Electronics Inc. All rights reserved."
                 FontSize="12"
                 Foreground="#374151"
                 Background="Transparent"
                 BorderThickness="0"
                 IsReadOnly="True"
                 IsTabStop="False"
                 Cursor="Arrow" />

        <!-- Contact -->
        <TextBlock Grid.Row="6"
                   Text="Bug reports &amp; improvement requests:"
                   FontSize="12"
                   Foreground="#6B7280" />

        <!-- Email: clickable link + copy button -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock VerticalAlignment="Center">
                <Hyperlink NavigateUri="mailto:sungyeon22.kim@lge.com"
                           RequestNavigate="OnHyperlinkRequestNavigate">
                    sungyeon22.kim@lge.com
                </Hyperlink>
            </TextBlock>
            <Button Content="📋 Copy"
                    Margin="10,0,0,0"
                    Padding="8,2"
                    FontSize="11"
                    VerticalAlignment="Center"
                    Cursor="Hand"
                    ToolTip="Copy email address to clipboard"
                    Click="OnCopyEmailClick"
                    Background="#F3F4F6"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1" />
        </StackPanel>

        <!-- Close Button -->
        <Button Grid.Row="10"
                Content="Close"
                HorizontalAlignment="Right"
                Padding="20,6"
                Click="OnCloseClick" />
    </Grid>
</Window>

